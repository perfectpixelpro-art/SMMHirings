# Copy to .env and fill in real values. .env is gitignored.

PORT=5001
NODE_ENV=development

# Local MongoDB (data dir: ~/Desktop/mongodb-data, port 27017)
MONGO_URI=mongodb://127.0.0.1:27017/smmhiring

# JWT secrets — use long random strings. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-random-access-secret
JWT_REFRESH_SECRET=replace-with-random-refresh-secret

# Resend (https://resend.com) — API key for sending email.
# If left as the placeholder, emails are logged to the server console instead
# of being sent, so the flow is testable without an account.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=SMM Hiring <onboarding@resend.dev>

# Frontend origin — used for CORS and for building email links.
CLIENT_URL=http://localhost:5173

# Admin (single fixed account — separate from the user auth system)
# Password is a bcrypt hash, not plaintext.
# Generate: node -e "console.log(require('bcryptjs').hashSync('YOUR_PW',12))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
